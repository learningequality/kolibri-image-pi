# Start with the base raspiOS-lite image
FROM images/source.img
TO images/base.img

ENV DEBIAN_FRONTEND noninteractive

user=pi

hostname=kolibri

RUN sed -i "s/raspberrypi/${hostname}/g" /etc/hostname /etc/hosts

# Debian 13+ DEB822-format PPAs
# See: https://kolibri.readthedocs.io/en/latest/install/ubuntu-debian.html#install-from-ppa-repository
RUN mkdir -p /etc/apt/keyrings
INSTALL 644 files/kolibri.asc /etc/apt/keyrings/kolibri.asc
INSTALL 644 files/learningequality-kolibri.sources /etc/apt/sources.list.d/
INSTALL 644 files/kolibri-server.asc /etc/apt/keyrings/kolibri-server.asc
INSTALL 644 files/learningequality-kolibri-server.sources /etc/apt/sources.list.d/

RUN mkdir -p "/home/${user}/.kolibri"
RUN mkdir -p /KOLIBRI_DATA/content
INSTALL 644 files/options.ini "/home/${user}/.kolibri/"

RUN chown -R ${user}:${user} /KOLIBRI_DATA
RUN chmod -R +rwx /KOLIBRI_DATA
RUN chown -R ${user}:${user} /home/${user}
RUN chmod -R +rwx /home/${user}

RUN apt-get update
RUN apt-get install -y nginx-full uwsgi uwsgi-plugin-python3 redis-server dnsmasq

RUN debconf-set-selections <<EOF
$(cat files/debconf)
EOF

# Set WiFi regulatory domain using raspi-config (the canonical tool).
# In the pimod chroot, raspi-config detects ischroot and skips runtime-only
# commands (iw reg set, nmcli radio wifi on).  The persistent file writes
# still succeed: cfg80211.ieee80211_regdom=US on the kernel command line.
RUN raspi-config nonint do_wifi_country US

# Override raspberrypi-sys-mods rfkill default (default_state=0 = blocked).
# Since we configure a known regulatory domain above, it is safe to default
# WiFi to unblocked.
RUN sed -i 's/default_state=0/default_state=1/' /etc/modprobe.d/rfkill_default.conf

# Pre-seed NetworkManager state so WiFi is enabled on first boot
RUN mkdir -p /var/lib/NetworkManager
INSTALL 644 files/NetworkManager.state /var/lib/NetworkManager/NetworkManager.state

# Install NetworkManager connection profile for WiFi hotspot AP
INSTALL 600 files/kolibri-hotspot.nmconnection /etc/NetworkManager/system-connections/kolibri-hotspot.nmconnection

INSTALL files/dnsmasq_hotspot.conf /etc/dnsmasq.d/hotspot.conf

INSTALL 644 files/99-usb.rules /etc/udev/rules.d/99-usb.rules
INSTALL 755 files/usb-mount.sh /usr/local/bin/usb-mount.sh
INSTALL 755 files/usb-mount@.service /etc/systemd/system/usb-mount@.service

RUN tee /etc/default/dnsmasq <<EOF
DNSMASQ_EXCEPT=lo
EOF

# Ensure dnsmasq reads drop-in config files (handles commented, uncommented, or missing line)
RUN sed -i -E '/^#?conf-dir=\/etc\/dnsmasq\.d/d' /etc/dnsmasq.conf

RUN tee -a /etc/dnsmasq.conf <<EOF
conf-dir=/etc/dnsmasq.d/,*.conf
EOF

RUN rm /etc/nginx/sites-enabled/default

RUN systemctl enable NetworkManager
RUN systemctl enable dnsmasq
RUN systemctl enable nginx
RUN systemctl enable ssh


# Set kolibryfly password for specified user (pi by default)
RUN bash -c 'echo pi:\$6\$OUzfiWw5K8RdwdFV\$7Skel9ojIekqNSE/KVPIhemg9D.tQqoOF2BwZwIgZ/X0CTC0MJPbcUmzvnSSE3CkBdG2zsD1rCHSQ9yQCqVfr/ > /boot/firmware/userconf.txt'

# avoid keyboard setup questions blocking first boot:
RUN sh -c 'echo "keyboard-configuration keyboard-configuration/layout select English (US)" | sudo debconf-set-selections'
# Append debconf=low to suppress keyboard setup questions on first boot
# (cmdline.txt must be a single line; regulatory domain is set by raspi-config above)
RUN sed -i '1s/$/ debconf=low/' /boot/firmware/cmdline.txt

ENV DEBIAN_FRONTEND
